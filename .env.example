# ---- Smartemis Agent: example environment file ----
# Copy to .env for local dev. In production (EC2 in eu-central-1) these
# are pulled from AWS Secrets Manager — never commit real secrets.

# --- Runtime ---
SMARTEMIS_ENV=local                # local | staging | production
SMARTEMIS_LOG_LEVEL=INFO

# --- Data source ---
SMARTEMIS_SOURCE=csv               # csv | qlik
SMARTEMIS_CSV_PATH=./synthetic_data/out/smartemis_lineitems.csv

# --- Database ---
# Local dev: SQLite. Production: Postgres in RDS eu-central-1.
SMARTEMIS_DB_URL=sqlite:///./smartemis.db

# --- LLM (AWS Bedrock in eu-central-1) ---
# In production, auth comes from the EC2 instance role, so no keys needed.
# For local dev against Bedrock, use an IAM user with Bedrock invoke perms.
AWS_REGION=eu-central-1
SMARTEMIS_BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6-v1:0
# Cross-region inference profile for Sonnet 4.6 in EU regions.
# If unavailable in your account, fall back to: anthropic.claude-sonnet-4-6-v1:0
# Never set ANTHROPIC_API_KEY here — we route exclusively via Bedrock for data residency.

# --- PII / pseudonymization ---
# HMAC salt for deterministic pseudonymization. In prod: pulled from Secrets Manager,
# rotated per Smartemis client. Different salts → different pseudonyms.
SMARTEMIS_PSEUDO_SALT=change-me-locally-use-32-bytes-random

# --- Qlik (placeholder for later) ---
QLIK_BASE_URL=
QLIK_API_KEY=
